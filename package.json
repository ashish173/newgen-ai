{
  "name": "pm-crm-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "DATABASE_URL=\"file:./dev.db\" prisma generate",
    "prisma:migrate": "DATABASE_URL=\"file:./dev.db\" prisma migrate dev --name init --force",
    "seed": "DATABASE_URL=\"file:./dev.db\" ts-node prisma/seed.ts",
    "test": "DATABASE_URL=\"file:./dev.db\" vitest run"
  },
  "dependencies": {
    "next": "14.1.4",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "zod": "3.23.8",
    "next-auth": "4.24.7",
    "exceljs": "4.3.0",
    "nodemailer": "8.0.10",
    "exifr": "7.1.3",
    "multer": "2.0.2",
    "bcryptjs": "2.4.3",
    "dotenv": "16.4.5",
    "@prisma/client": "5.15.1"
  },
  "devDependencies": {
    "typescript": "5.4.5",
    "prisma": "5.15.1",
    "tailwindcss": "3.4.10",
    "postcss": "8.4.47",
    "autoprefixer": "10.4.20",
    "vitest": "1.6.0",
    "ts-node": "10.9.2",
    "supertest": "6.3.3",
    "@types/node": "20.11.30",
    "@types/react": "18.2.66",
    "@types/react-dom": "18.2.23",
    "@types/bcryptjs": "2.4.2",
    "@types/multer": "1.4.7",
    "@types/nodemailer": "8.0.1",
    "@types/supertest": "2.0.12"
  }
}
